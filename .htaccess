# DVSwitch Modern Dashboard URL Rewriting
RewriteEngine On

# Allow direct access to real files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Redirect paths to the dashboard configuration
# Example: /P25_NA -> index.php?conf=P25_NA
RewriteRule ^([^/]+)/?$ index.php?conf=$1 [QSA,L]
